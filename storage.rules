rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Photos de prélèvements
    // Chemin : samplings/{clientId}/{planId}/{samplingId}/{filename}
    // Lecture et écriture réservées aux utilisateurs authentifiés
    match /samplings/{clientId}/{planId}/{samplingId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Photos de visites préliminaires
    // Chemin : visites/{visiteId}/{pointId}/{filename}
    match /visites/{visiteId}/{pointId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Photos de plans de prélèvement (Mémoire du point / Fiche)
    // Chemin : plans/{clientId}/{planId}/{filename}
    match /plans/{clientId}/{planId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Photos de messagerie
    // Chemin : chats/{chatId}/{filename}
    // Canal général (chatId = 'general') : tout utilisateur authentifié.
    // DM (chatId = 'uidA_uidB', cf. getDmChatId) : réservé aux deux participants,
    // pour que les photos privées aient la même isolation que le texte (firestore.rules).
    match /chats/{chatId}/{filename} {
      function isChatParticipant() {
        return chatId == 'general' || request.auth.uid in chatId.split('_');
      }
      allow read: if request.auth != null && isChatParticipant();
      allow create, update: if request.auth != null
        && isChatParticipant()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && isChatParticipant();
    }

  }
}

