rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Photos de prélèvements
    // Chemin : samplings/{clientId}/{planId}/{samplingId}/{filename}
    // Lecture et écriture réservées aux utilisateurs authentifiés
    match /samplings/{clientId}/{planId}/{samplingId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Photos de visites préliminaires
    // Chemin : visites/{visiteId}/{pointId}/{filename}
    match /visites/{visiteId}/{pointId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Photos de plans de prélèvement (Mémoire du point / Fiche)
    // Chemin : plans/{clientId}/{planId}/{filename}
    match /plans/{clientId}/{planId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Photos de messagerie
    // Chemin : chats/{chatId}/{filename}
    match /chats/{chatId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

  }
}

