# Firebase — Clés du projet (Firebase Console > Paramètres du projet > Vos applications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Firebase Cloud Messaging — Clé publique VAPID (Console Firebase > Cloud Messaging > Configuration Web)
VITE_FIREBASE_VAPID_KEY=
# Sentry — DSN du projet (labocea.sentry.io > Settings > Client Keys)
VITE_SENTRY_DSN=
# Version de l'app (injectée au build, remontée dans Sentry pour tracer les releases)
VITE_APP_VERSION=
