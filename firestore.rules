rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── clients-v2 ────────────────────────────────────────────
    // Lecture et écriture réservées aux utilisateurs authentifiés (V2 uniquement).
    // La V1 (sans auth) ne peut plus écrire dans cette collection.
    match /clients-v2/{clientId} {
      allow read, write: if isAuthenticated();
    }

    // ── users ─────────────────────────────────────────────────
    // Lecture : tout utilisateur authentifié (dénormalisation noms/initiales).
    // Écriture propre profil : tout utilisateur authentifié.
    // Écriture profil tiers (création/suppression comptes) : admin uniquement.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // ── equipements ───────────────────────────────────────────
    match /equipements/{equipementId} {
      allow read, write: if isAuthenticated();
    }

    // ── verifications ─────────────────────────────────────────
    match /verifications/{verificationId} {
      allow read, write: if isAuthenticated();
    }

    // ── maintenances ──────────────────────────────────────────
    match /maintenances/{maintenanceId} {
      allow read, write: if isAuthenticated();
    }

    // ── evenements ────────────────────────────────────────────
    match /evenements/{evenementId} {
      allow read, write: if isAuthenticated();
    }

    // ── demandes ──────────────────────────────────────────────
    match /demandes/{demandeId} {
      allow read, write: if isAuthenticated();
    }

    // ── tuyaux ───────────────────────────────────────────────────
    match /tuyaux/{tuyauId} {
      allow read, write: if isAuthenticated();
    }

    // ── clients (V1 — archive, lecture seule) ─────────────────
    // La collection V1 reste accessible en lecture uniquement.
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

  }
}
