rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Vérifie qu'aucun des champs listés n'est modifié sur un update
    function immutableOn(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function hasRequiredClientFields() {
      return request.resource.data.keys().hasAll(['nom', 'annee']) &&
        request.resource.data.nom is string &&
        request.resource.data.nom.size() > 0 &&
        request.resource.data.annee is string &&
        request.resource.data.annee.size() > 0;
    }

    // ── clients-v2 ────────────────────────────────────────────
    // Lecture et create/update : tout utilisateur authentifié.
    // Suppression : admin uniquement (données critiques métier).
    match /clients-v2/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && hasRequiredClientFields();
      allow update: if isAuthenticated() && immutableOn(['createdBy', 'annee']);
      allow delete: if isAdmin();
    }

    // ── users ─────────────────────────────────────────────────
    // Lecture : tout utilisateur authentifié (dénormalisation noms/initiales).
    // Écriture propre profil : tout utilisateur authentifié.
    // Écriture profil tiers (création/suppression comptes) : admin uniquement.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && request.resource.data.role == 'technicien')
      );
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email'])))
      );
      allow delete: if isAdmin();
    }

    // ── equipements ───────────────────────────────────────────
    // Suppression : admin uniquement.
    match /equipements/{equipementId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && immutableOn(['createdBy']);
      allow delete: if isAdmin();
    }

    // ── verifications ─────────────────────────────────────────
    // Suppression : admin uniquement.
    match /verifications/{verificationId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && immutableOn(['createdBy', 'equipementId']);
      allow delete: if isAdmin();
    }

    // ── maintenances ──────────────────────────────────────────
    // Suppression : admin uniquement.
    match /maintenances/{maintenanceId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && immutableOn(['createdBy', 'equipementId']);
      allow delete: if isAdmin();
    }

    // ── evenements ────────────────────────────────────────────
    match /evenements/{evenementId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && immutableOn(['createdBy']);
      allow delete: if isAdmin();
    }

    // ── demandes ──────────────────────────────────────────────
    match /demandes/{demandeId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && immutableOn(['createdBy']);
      allow delete: if isAdmin();
    }

    // ── tuyaux ────────────────────────────────────────────────
    match /tuyaux/{tuyauId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && immutableOn(['createdBy']);
      allow delete: if isAdmin();
    }

    // ── points-rejet ──────────────────────────────────────────
    match /points-rejet/{pointId} {
      allow read, create: if isAuthenticated();
      allow update: if isAuthenticated() && immutableOn(['createdBy']);
      allow delete: if isAdmin();
    }

    // ── bugs ──────────────────────────────────────────────────
    // Création : tout utilisateur authentifié.
    // Lecture/suppression : admin uniquement.
    match /bugs/{bugId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // ── visites préliminaires ──────────────────────────────────
    // Création/lecture : tout utilisateur authentifié.
    // Modification/suppression : technicien créateur ou admin.
    match /visites/{visiteId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (request.auth.uid == resource.data.technicienUid || isAdmin());
    }

    // ── todos ─────────────────────────────────────────────────
    match /todos/{todoId} {
      allow read, create, update: if isAuthenticated();
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.createdBy || isAdmin());
    }

    // ── chat-messages ─────────────────────────────────────────
    // Les messages généraux sont lisibles par tous. Les DMs ne sont lisibles et scriptibles
    // que par leurs participants autorisés. L'historique est immuable.
    match /chat-messages/{messageId} {
      allow read: if isAuthenticated() && (
        !('chatId' in resource.data) ||
        resource.data.chatId == 'general' ||
        (request.auth.uid in resource.data.participants)
      );
      allow create: if isAuthenticated() && (
        !('chatId' in request.resource.data) ||
        request.resource.data.chatId == 'general' ||
        (request.auth.uid in request.resource.data.participants)
      );
      // Seul le champ pollVotes peut être modifié (vote sur un sondage) ;
      // tout le reste du message (texte, image, sondage) reste immuable.
      allow update: if isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pollVotes']);
      allow delete: if false;
    }

    // ── clients (V1 — archive, lecture seule) ─────────────────
    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── preleveurs (V1 — archive, lecture seule) ──────────────
    match /preleveurs/{preleveurId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── preleveurs-v1 (liste consolidée, éditable par admin) ──
    match /preleveurs-v1/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

  }
}
